# Optional -- lib/supabaseClient.js already defaults to the real Mimi's
# Supabase project + anon key (same publicly-safe key already hardcoded in
# dashboard/index.html and kds/index.html). Only set these to point a build
# at a different Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://igchqqyassrfpsliyjec.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required in Vercel. This is a real secret -- get the value from the n8n
# credential "ktcaEXqFFkXA1wWT" (X-Mimis-Webhook-Secret) and set it in the
# Vercel project's Environment Variables, never commit it here.
MIMIS_WEBHOOK_SECRET=

# Optional -- defaults to https://automation.teamastrixdev.com
MIMIS_N8N_BASE_URL=
